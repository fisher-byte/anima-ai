# Anima Environment Configuration
# Copy this file to .env and fill in your values

# Server port (default: 3000)
PORT=3000

# Data directory for SQLite persistence
# In Docker: mount a volume here
DATA_DIR=./data

# Authentication (optional, for public deployment)
# Set to true to require Bearer token on all /api/* requests
AUTH_ENABLED=false

# Static Bearer token (required when AUTH_ENABLED=true)
# ACCESS_TOKEN=your-secret-token-here

# Vite API URL override (used in Electron mode only)
# VITE_API_URL=https://api.moonshot.cn/v1
