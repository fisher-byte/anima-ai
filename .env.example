# Anima Environment Configuration
# Copy this file to .env and fill in your values

# Server port (default: 3000)
PORT=3000

# Data directory for SQLite persistence
# In Docker: mount a volume here
DATA_DIR=./data

# Authentication (default: 鉴权开启，Fail Closed)
# 默认情况下鉴权已开启；将此变量设为 true 才会跳过鉴权（仅用于本地开发）
# 注意：变量名为 AUTH_DISABLED（非 AUTH_ENABLED），设为 true = 关闭鉴权
AUTH_DISABLED=false

# Static Bearer token（当鉴权开启时必填，即未设置 AUTH_DISABLED=true 时）
# ACCESS_TOKEN=your-secret-token-here

# Vite API URL override (used in Electron mode only)
# VITE_API_URL=https://api.moonshot.cn/v1
