# Anima Environment Configuration
# Copy this file to .env and fill in your values

# Server port (default: 3000)
PORT=3000

# Data directory for SQLite persistence
# In Docker: mount a volume here
DATA_DIR=./data

# Authentication — open product mode (no login required)
# Users get auto-generated UUID tokens stored in localStorage.
# No ACCESS_TOKEN whitelist needed; any token is accepted as a user ID.
AUTH_DISABLED=false

# Shared API Key — used for all users who haven't set their own key
# Users with their own key (set in Settings) use that instead
SHARED_API_KEY=sk-your-shared-key-here

# Daily cost limit per user when using the shared key (default: ¥5)
# Based on moonshot-v1-8k pricing ¥0.012/1K tokens. Users with their own key are not subject to this limit.
DAILY_LIMIT_YUAN=5

# Vite API URL override (used in Electron mode only)
# VITE_API_URL=https://api.moonshot.cn/v1
